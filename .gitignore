# Ignore everything
*

# Git
!.git
!.git/**
!.gitignore

# Project
!README.md
!CHANGELOG.md
!LICENSE-*
!deny.toml
!release-plz.toml
!.github/
!.github/workflows/
!.github/**/*.yml
!.github/scripts/
!.github/**/*.py

# Rust
!Cargo.toml
!Cargo.lock
!rust-toolchain
!rustfmt.toml
!.cargo/
!.cargo/config.toml
!typewire/
!typewire/src/
!typewire/tests/
!typewire/tests/common/
!typewire/tests/compile_fail/
!typewire/tests/compile_fail/*.stderr
!typewire/**/*.rs
!typewire-derive/
!typewire-derive/src/
!typewire-derive/**/*.rs
!typewire-schema/
!typewire-schema/src/
!typewire-schema/tests/
!typewire-schema/**/*.rs

# Rust (examples)
!examples/
!examples/*/
!examples/*/Cargo.toml
!examples/*/README.md
!examples/*/*.ts
!examples/*/*.d.ts
examples/*/*.gen.d.ts
!examples/*/tsconfig.json
!examples/*/package.json
!examples/*/src/
!examples/**/*.rs

# Rust (xtask)
!xtask/
!xtask/Cargo.toml
!xtask/src/
!xtask/**/*.rs

# Experiments
!experiments/
!experiments/*/
!experiments/**/*.wat
!experiments/**/*.wasm
!experiments/**/*.mjs

# Claude
!CLAUDE.md
!.claude/
!.claude/settings.json
!.claude/commands/
!.claude/**/*.md
